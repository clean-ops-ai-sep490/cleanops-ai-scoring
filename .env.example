# =========================
# Server runtime
# =========================
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true
REQUEST_TIMEOUT_SEC=30
APP_PUBLIC_BASE_URL=http://localhost:8000
SCORING_REQUIREMENTS_FILE=requirements.inference.txt
SCORING_TRAIN_COMMAND=python src/train_yolo.py

# =========================
# API scoring and limits
# =========================
YOLO_CONF=0.25
MAX_BATCH_IMAGES=5
PENDING_LOWER_BOUND=50
VISUALIZE_JPEG_QUALITY=92
VISUALIZE_TEMP_URL_TTL_SEC=900
VISUALIZE_TEMP_MAX_ITEMS=200

ENV_PASS_THRESHOLD_LOBBY_CORRIDOR=90
ENV_PASS_THRESHOLD_RESTROOM=85
ENV_PASS_THRESHOLD_BASEMENT_PARKING=80
ENV_PASS_THRESHOLD_GLASS_SURFACE=90
ENV_PASS_THRESHOLD_OUTDOOR_LANDSCAPE=80
ENV_PASS_THRESHOLD_HOSPITAL_OR=95

# Optional JSON override for full env rules map
# ENV_RULES_JSON={"LOBBY_CORRIDOR":{"pass_threshold":90,"label":"Lobby"}}

# =========================
# Model paths
# =========================
# BASE_OUTPUT_DIR can be relative to project root or absolute
BASE_OUTPUT_DIR=outputs

# Leave MODEL_PATH empty to auto-pick latest outputs/**/best.pt
MODEL_PATH=
UNET_MODEL_PATH=models/unet_multiclass_best.pth
UNET_IMG_SIZE=384
MODEL_CACHE_DIR=model-cache
MODEL_STORAGE_ENABLED=true
MODEL_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<storage_account>;AccountKey=<account_key>;EndpointSuffix=core.windows.net
MODEL_STORAGE_CONTAINER=models
MODEL_STORAGE_ACTIVE_YOLO_KEY=scoring/active/yolo/model.pt
MODEL_STORAGE_ACTIVE_UNET_KEY=scoring/active/unet/model.pth
MODEL_FORCE_REFRESH=false
MODEL_REQUIRE_BLOB=true
SCORING_BLOB_NAMESPACE=scoring
SCORING_BLOB_MODELS_CONTAINER=models
SCORING_BLOB_RETRAIN_CONTAINER=retrain
SCORING_BLOB_EXTERNAL_PREFIX=scoring/external/latest
SCORING_BLOB_ACTIVE_MANIFEST_KEY=scoring/manifests/active.json

# =========================
# Dataset download credentials
# =========================
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_DATASET=alyyan/trash-detection

ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=compvision-bfglv
ROBOFLOW_PROJECT=clean-unclean-floor
ROBOFLOW_VERSION=1

# =========================
# YOLO training defaults
# =========================
YOLO_RAW_DIR=data/raw/yolo
YOLO_DATA_YAML=data/raw/yolo/roboflow_clean/data.yaml
YOLO_WEIGHTS_PATH=yolov8n.pt
YOLO_TRAIN_EPOCHS=50
YOLO_TRAIN_BATCH=16
YOLO_TRAIN_IMGSZ=640
YOLO_PROJECT_DIR=outputs/yolo
YOLO_RUN_NAME=trash_detection
YOLO_DEVICE=0
YOLO_USE_HALF=true

# =========================
# U-Net preprocess defaults
# =========================
HD10K_ROOT=unet_dataset/HD10K_IROS2022
STAGNANT_ROOT=unet_dataset/Stagnant Water and Wet Surface Dataset-fJZUTl/Stagnant Water and Wet Surface Dataset
UNET_PROCESSED_ROOT=data/processed/unet_multiclass
RANDOM_SEED=42
